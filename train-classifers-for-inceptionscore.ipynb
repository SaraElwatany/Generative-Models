    "def evaluate(model, loader, device=device):\n",
    "\n",
    "    \"\"\"\n",
    "    Evaluates model accuracy on a given dataset loader.\n",
    "\n",
    "    Args:\n",
    "        model (nn.Module): The model to evaluate.\n",
    "        loader (DataLoader): DataLoader for the evaluation set.\n",
    "        device (torch.device): Device to run inference on (CPU or CUDA).\n",
    "\n",
    "    Returns:\n",
    "        float: Accuracy as a ratio of correct predictions to total samples.\n",
    "    \"\"\"\n",
    "    \n",
    "    model.eval()\n",
    "    correct = 0\n",
    "    total = 0\n",
    "\n",
    "    with torch.no_grad():\n",
    "        \n",
    "        for images, labels in loader:\n",
    "            \n",
    "            images, labels = images.to(device), labels.to(device)\n",
    "            outputs = model(images)\n",
    "            preds = outputs.argmax(dim=1)\n",
    "\n",
    "            correct += (preds == labels).sum().item()\n",
    "            total += labels.size(0)\n",
    "\n",
    "    return correct / total"
   ]
  },
