    "def get_model(num_classes):\n",
    "    \n",
    "    \"\"\"\n",
    "    Loads a pretrained ResNet-18 and replaces its classifier head for fine-tuning.\n",
    "\n",
    "    Args:\n",
    "        num_classes (int): Number of output classes for the final fully connected layer.\n",
    "\n",
    "    Returns:\n",
    "        nn.Module: ResNet-18 model pretrained on ImageNet with a replaced FC layer.\n",
    "    \"\"\"\n",
    "    \n",
    "    model = models.resnet18(weights=models.ResNet18_Weights.IMAGENET1K_V1)\n",
    "    model.fc = nn.Linear(model.fc.in_features, num_classes)\n",
    "    \n",
    "    return model"
   ]
  },
  {
   "cell_type": "code",
