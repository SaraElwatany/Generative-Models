    "def train_model(model, optimizer, criterion, scheduler, scaler, train_loader, test_loader, epochs=100, min_delta=0.0001, patience=10, dataset='mnist', device=device):\n",
    "\n",
    "    \"\"\"\n",
    "    Trains a model with early stopping and saves the best checkpoint.\n",
    "\n",
    "    Args:\n",
    "        model (nn.Module): The neural network model to train.\n",
    "        optimizer (torch.optim.Optimizer): Optimizer for updating model weights.\n",
    "        criterion (nn.Module): Loss function.\n",
    "        scheduler (torch.optim.lr_scheduler): Learning rate scheduler, stepped each epoch.\n",
    "        train_loader (DataLoader): DataLoader for the training set.\n",
    "        test_loader (DataLoader): DataLoader for the test set.\n",
    "        epochs (int): Maximum number of training epochs. Defaults to 100.\n",
    "        min_delta (float): Minimum accuracy improvement to count as progress. Defaults to 0.0001.\n",
    "        patience (int): Epochs to wait without improvement before early stopping. Defaults to 10.\n",
    "        dataset (str): Dataset name, used to name the saved checkpoint file. Defaults to 'mnist'.\n",
    "        device (torch.device): Device to run training on (CPU or CUDA).\n",
    "\n",
    "    Returns:\n",
    "        None. Prints per-epoch loss/accuracy and saves the best model to `{dataset}_best.pth`.\n",
    "    \"\"\"\n",
    "\n",
    "    \n",
    "    # Initialize early stopping parameters\n",
    "    best_acc = 0\n",
    "    patience_counter = 0\n",
    "    \n",
    "\n",
    "    # Loop through the dataset for number of times\n",
    "    for epoch in range(epochs):\n",
    "\n",
    "\n",
    "        # Set the model to the training mode\n",
    "        model.train()\n",
    "        total_loss = 0       # Initialize the total loss\n",
    "    \n",
    "\n",
    "        # For each batch  perform forward and backward pass\n",
    "        for images, labels in train_loader:\n",
    "            \n",
    "            images, labels = images.to(device), labels.to(device)\n",
    "    \n",
    "            optimizer.zero_grad()\n",
    "    \n",
    "            with torch.cuda.amp.autocast():\n",
    "                outputs = model(images)\n",
    "                loss = criterion(outputs, labels)\n",
    "    \n",
    "            scaler.scale(loss).backward()\n",
    "            scaler.step(optimizer)\n",
    "            scaler.update()\n",
    "    \n",
    "            total_loss += loss.item()\n",
    "\n",
    "        # Compute metrics\n",
    "        loss = total_loss / len(train_loader)\n",
    "        acc = evaluate(model, test_loader)\n",
    "        scheduler.step()\n",
    "\n",
    "        print(f\"Epoch {epoch+1}: Train Loss={loss:.4f}, Test Acc={acc:.4f}\")\n",
    "\n",
    "        \n",
    "        # Check improvement\n",
    "        if acc > best_acc + min_delta:\n",
    "            \n",
    "            best_acc = acc\n",
    "            patience_counter = 0\n",
    "\n",
    "            torch.save(model.state_dict(), f\"{dataset}_best.pth\")\n",
    "            print(\"New best model saved\")\n",
    "            \n",
    "\n",
    "        else:\n",
    "            patience_counter += 1\n",
    "            print(f\"No improvement ({patience_counter}/{patience})\")\n",
    "\n",
    "        # Early stopping condition\n",
    "        if patience_counter >= patience:\n",
    "            print(f\"\\n Early stopping triggered at epoch {epoch+1}\")\n",
    "            break\n",
    "\n",
    "    print(f\"Best Accuracy: {best_acc:.4f}\")"
   ]
  },
